{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Wallpaper House",
  "version": "0.1.0",
  "identifier": "com.wallpaperhouse.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Wallpaper House",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "category": "Utility",
    "shortDescription": "Cross-platform desktop wallpaper manager",
    "longDescription": "Wallpaper House is a premium cross-platform desktop wallpaper application for discovering, managing, and setting beautiful wallpapers with AI-powered recommendations and cross-device sync.",
    "copyright": "Copyright 2026 Wallpaper House",
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"]
      },
      "rpm": {
        "depends": ["webkit2gtk4.1", "gtk3"]
      }
    },
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "",
      "endpoints": [
        "https://github.com/Rukaiya-Akhter-Zerin/Wallpaper-House-2026/releases/latest/download/latest.json"
      ]
    }
  }
}
